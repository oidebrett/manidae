# Pangolin Platform Environment Variables
# Copy this file to .env and fill in the values

# Required Pangolin Configuration
DOMAIN=example.com
EMAIL=admin@example.com

# Optional Pangolin Configuration
ADMIN_SUBDOMAIN=pangolin
ADMIN_USERNAME=admin@example.com
ADMIN_PASSWORD=changeme
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=pangolin-postgres

# Optional Component Subdomains
TRAEFIK_SUBDOMAIN=traefik
MIDDLEWARE_MANAGER_SUBDOMAIN=middleware
KOMODO_SUBDOMAIN=komodo
NLWEB_SUBDOMAIN=nlweb
LOGS_SUBDOMAIN=logs
STATIC_PAGE_SUBDOMAIN=www

# Optional Component Configuration
# CrowdSec Security
CROWDSEC_ENROLLMENT_KEY=

# OAuth Authentication
CLIENT_ID=
CLIENT_SECRET=
OAUTH_DOMAIN=oauth.example.com

# Komodo Server Management (requires KOMODO_HOST_IP to enable)
KOMODO_HOST_IP=
KOMODO_PASSKEY=
KOMODO_TITLE=
KOMODO_FIRST_SERVER=
COMPOSE_KOMODO_IMAGE_TAG=latest

# AI/NLWeb Configuration (requires at least one API key to enable)
OPENAI_API_KEY=
AZURE_OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Traefik Log Dashboard (requires MAXMIND_LICENSE_KEY to enable)
MAXMIND_LICENSE_KEY=

# ================================
# MCP Gateway Configuration
# ================================
# Component Subdomains
MCP_GATEWAY_SUBDOMAIN=mcpgateway
OPENMEMORY_SUBDOMAIN=memory
LANGWATCH_SUBDOMAIN=langwatch
PANGOLIN_API_SUBDOMAIN=api

# LLM Provider (OpenRouter recommended for multi-model support)
OPENROUTER_API_KEY=
SIMULATION_MODEL=google/gemini-2.0-flash-001
CHAT_MODEL=google/gemini-2.0-flash-001
SKILLS_BUILDER_MODEL=google/gemini-2.0-flash-001

# LangWatch Observability
LANGWATCH_API_KEY=

# Pangolin Integration API
PANGOLIN_API_KEY=
PANGOLIN_API_URL=
PANGOLIN_ORG_ID=admin

# Komodo Integration (for MCP Gateway)
# KOMODO_API_KEY=
# KOMODO_API_SECRET=
# KOMODO_API_URL=

# OpenMemory Configuration
OM_API_KEY=
OM_MODE=standard
OM_TIER=hybrid
OM_EMBEDDINGS=synthetic

# Nango Integration (optional)
NANGO_SECRET_KEY=
NANGO_DEFAULT_USER_ID=
NANGO_API_URL=https://api.nango.dev
NANGO_MCP_URL=https://api.nango.dev/mcp

# Vercel Integration (optional)
VERCEL_TOKEN=
VERCEL_TEAM_ID=
VERCEL_PROJECT_ID=

# MCP Registry
MCP_REGISTRY_URL=http://mcp-registry:8080

# System Configuration
TZ=Etc/UTC
